# Claude / Anthropic auth
# One of these should be set before running SDK scripts
# Get OAuth token via Claude CLI: `claude setup-token`
CLAUDE_CODE_OAUTH_TOKEN=

# Or use an Anthropic API key from the Anthropic Console
ANTHROPIC_API_KEY=
# Airtable configuration
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Prospects